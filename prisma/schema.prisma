generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum BusinessRole {
  OWNER
  ADMIN
  STAFF
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum ResourceType {
  PERSON
  ASSET
}

enum ResourceStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
  DELETED
}

model Business {
  id                            String         @id @default(uuid())
  name                          String
  slug                          String         @unique
  timezone                      String
  resourceLabel                 String         @default("Recurso")
  address                       String?
  area                          String?
  status                        BusinessStatus @default(ACTIVE)
  remindersEnabled              Boolean        @default(true)
  reminderOffsetsMinutes        Int[]          @default([1440, 120]) // 24h y 2h antes
  emailNotificationsEnabled     Boolean        @default(true)
  whatsappNotificationsEnabled  Boolean        @default(false)
  ownerEmail                    String?        // email del owner para notificaciones al negocio
  ownerPhoneE164                String?        // teléfono del owner en E.164 para WhatsApp
  ownerEmailNotificationsEnabled    Boolean    @default(true)
  ownerWhatsappNotificationsEnabled Boolean    @default(false)
  ownerRemindersEnabled             Boolean    @default(false)
  ownerReminderOffsetsMinutes       Int[]      @default([])
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt

  members                  BusinessMember[]
  resources                Resource[]
  services                 Service[]
  serviceResources         ServiceResource[]
  customers                Customer[]
  appointments             Appointment[]
  notifications            Notification[]

  @@index([status])
}

model BusinessMember {
  id         String       @id @default(uuid())
  businessId String
  userId     String       // Supabase Auth user id (UUID en string)
  role       BusinessRole  @default(OWNER)
  createdAt  DateTime      @default(now())

  business   Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
  @@index([businessId])
}

model Resource {
  id         String         @id @default(uuid())
  businessId String
  name       String
  type       ResourceType?
  status     ResourceStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  availabilityRules AvailabilityRule[]
  blocks            ResourceBlock[]
  serviceResources  ServiceResource[]
  appointments      Appointment[]

  // Note: Partial unique index on (businessId, name) WHERE status != 'DELETED'
  // is defined in migration 20260128000000_soft_delete_partial_unique_index
  // This allows reusing names after soft delete.
  @@index([businessId])
  @@index([status])
}

model AvailabilityRule {
  id           String   @id @default(uuid())
  resourceId   String
  dayOfWeek    Int      // 0=Domingo, 1=Lunes, ..., 6=Sábado
  startMinutes Int      // Minutos desde 00:00 (ej: 540 = 09:00)
  endMinutes   Int      // Minutos desde 00:00 (ej: 1080 = 18:00)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resource     Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
  @@index([resourceId, dayOfWeek])
}

model Service {
  id                      String        @id @default(uuid())
  businessId              String
  name                    String
  description             String?
  durationMinutes         Int
  slotIntervalMinutes     Int           // Periodicidad: cada cuántos minutos se ofrece un nuevo turno
  minBookingNoticeMinutes Int           @default(0) // Anticipación mínima para reservas (minutos)
  priceCents              Int?
  currency                String?       @default("ARS")
  status                  ServiceStatus @default(ACTIVE)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceResources ServiceResource[]
  appointments     Appointment[]

  // Note: Partial unique index on (businessId, name) WHERE status != 'DELETED'
  // is defined in migration 20260128000000_soft_delete_partial_unique_index
  // This allows reusing names after soft delete.
  @@index([businessId])
  @@index([businessId, status])
}

model ResourceBlock {
  id         String   @id @default(uuid())
  resourceId String
  startAt    DateTime // inicio del bloqueo (UTC)
  endAt      DateTime // fin del bloqueo (UTC)
  reason     String?  // motivo opcional
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
  @@index([resourceId, startAt, endAt])
}

model ServiceResource {
  id         String   @id @default(uuid())
  businessId String
  serviceId  String
  resourceId String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, resourceId])
  @@index([businessId, serviceId])
  @@index([businessId, resourceId])
}

// ============================================================================
// US-5.4: Customers & Appointments
// ============================================================================

enum AppointmentStatus {
  SCHEDULED
  CANCELLED
  RESCHEDULED
  COMPLETED
}

model Customer {
  id         String   @id @default(uuid())
  businessId String
  fullName   String
  email      String?
  phone      String?
  phoneE164  String?  // Normalized phone in E.164 format for WhatsApp
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, email])
  @@index([businessId, phone])
  // Note: Unique constraint on (businessId, email) WHERE email IS NOT NULL
  // is defined in migration 20260107100000_customer_unique_email
}

model Appointment {
  id                 String            @id @default(uuid())
  businessId         String
  resourceId         String
  serviceId          String
  customerId         String
  status             AppointmentStatus @default(SCHEDULED)
  startAt            DateTime          @db.Timestamptz // inicio del turno (UTC)
  endAt              DateTime          @db.Timestamptz // fin del turno (UTC) = startAt + duration
  occupiedEndAt      DateTime          @db.Timestamptz // fin ocupación (UTC) = startAt + slotInterval
  notes              String?
  cancellationReason String?
  createdByUserId    String?           // null si fue creado por cliente público
  rescheduledFromId  String?           // referencia a appointment original si fue reprogramado
  secretToken        String            @default(uuid()) // capability URL token para autogestión del cliente
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  business         Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  resource         Resource     @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  service          Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customer         Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rescheduledFrom  Appointment? @relation("RescheduledAppointments", fields: [rescheduledFromId], references: [id])
  rescheduledTo    Appointment[] @relation("RescheduledAppointments")
  notifications    Notification[]

  @@index([businessId, startAt])
  @@index([resourceId, startAt])
  @@index([customerId])
  @@index([status])
  @@unique([secretToken])
}

// ============================================================================
// US-8.1: Notifications
// ============================================================================

enum NotificationRecipient {
  CUSTOMER
  BUSINESS
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationType {
  CONFIRMATION
  REMINDER
  CANCELLATION
  RESCHEDULED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id            String                @id @default(uuid())
  businessId    String
  appointmentId String
  channel       NotificationChannel
  type          NotificationType
  recipient     NotificationRecipient @default(CUSTOMER)
  to            String                // email address or phone_e164
  status        NotificationStatus    @default(PENDING)
  scheduledFor  DateTime              @db.Timestamptz // When the notification should be sent
  sentAt        DateTime?             @db.Timestamptz // When it was actually sent
  error         String?               // Error message if failed
  createdAt     DateTime              @default(now()) @db.Timestamptz
  updatedAt     DateTime              @updatedAt @db.Timestamptz

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  // Idempotency: prevent duplicate notifications per channel and recipient
  // Allows same appointment to have independent notifications for CUSTOMER and BUSINESS
  @@unique([appointmentId, channel, type, scheduledFor, recipient])
  @@index([businessId])
  @@index([appointmentId])
  @@index([status])
  @@index([channel])
  @@index([recipient])
}

// ============================================================================
// Subscriptions & Payments
// ============================================================================

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum TrialType {
  STANDARD
  SPECIAL
}

enum PaymentProvider {
  STRIPE
  MERCADOPAGO
}

enum PaymentTransactionType {
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND
}

enum PaymentTransactionStatus {
  SUCCEEDED
  FAILED
  PENDING
}

enum SubscriptionNotificationType {
  TRIAL_EXPIRING
  TRIAL_EXPIRED
  PAYMENT_FAILED
  SUBSCRIPTION_CANCELED
}

model SubscriptionPlan {
  id              String   @id @default(uuid())
  name            String   // e.g. "Pro Mensual"
  slug            String   @unique // e.g. "pro-monthly"
  priceCents      Int      // e.g. 4990
  currency        String   // e.g. "ARS", "USD"
  intervalMonths  Int      @default(1)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   Subscription[]
  scheduledSubscriptions Subscription[] @relation("ScheduledPlan")
}

model Subscription {
  id                       String             @id @default(uuid())
  userId                   String             @unique // Supabase Auth user UUID
  countryIso2              String?
  planId                   String?
  scheduledPlanId          String?
  status                   SubscriptionStatus @default(TRIALING)
  trialStartsAt            DateTime
  trialEndsAt              DateTime
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  scheduledPlanEffectiveAt DateTime?
  cancelAt                 DateTime?          // "cancel at end of period" target date
  canceledAt               DateTime?          // when cancellation was requested
  gracePeriodEndsAt        DateTime?
  paymentProvider          PaymentProvider?
  providerCustomerId       String?            // customer ID in provider
  providerSubscriptionId   String?            // subscription ID in provider
  trialType                TrialType          @default(STANDARD)
  trialLinkId              String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  plan                     SubscriptionPlan?  @relation(fields: [planId], references: [id])
  scheduledPlan            SubscriptionPlan?  @relation("ScheduledPlan", fields: [scheduledPlanId], references: [id])
  trialLink                TrialLink?         @relation(fields: [trialLinkId], references: [id])
  paymentTransactions      PaymentTransaction[]
  subscriptionNotifications SubscriptionNotification[]

  @@index([status])
  @@index([countryIso2])
  @@index([trialEndsAt])
  @@index([currentPeriodEnd])
  @@index([scheduledPlanId])
  @@index([scheduledPlanEffectiveAt])
}

model PaymentTransaction {
  id                String                   @id @default(uuid())
  subscriptionId    String
  provider          PaymentProvider
  providerEventId   String                   @unique // idempotency key
  providerPaymentId String?
  type              PaymentTransactionType
  amountCents       Int
  currency          String
  status            PaymentTransactionStatus
  metadata          Json?                    // raw provider payload
  createdAt         DateTime                 @default(now())

  subscription      Subscription             @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

model TrialLink {
  id         String    @id @default(uuid())
  code       String    @unique
  trialDays  Int       @default(60)
  maxUses    Int?      // null = unlimited
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  metadata   Json?     // campaign, source, etc.
  createdBy  String?   // who generated this link
  createdAt  DateTime  @default(now())

  usages        TrialLinkUsage[]
  subscriptions Subscription[]
}

model TrialLinkUsage {
  id          String    @id @default(uuid())
  trialLinkId String
  userId      String    // Supabase Auth user UUID
  usedAt      DateTime  @default(now())
  convertedAt DateTime? // set when the user pays (for conversion metrics)

  trialLink   TrialLink @relation(fields: [trialLinkId], references: [id], onDelete: Cascade)

  @@unique([trialLinkId, userId])
  @@index([trialLinkId])
}

model SubscriptionConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model SubscriptionNotification {
  id              String                       @id @default(uuid())
  subscriptionId  String
  userId          String                       // Supabase Auth user UUID
  type            SubscriptionNotificationType
  channel         NotificationChannel          @default(EMAIL)
  daysRemaining   Int?                         // for trial warnings
  to              String                       // email destination
  status          NotificationStatus           @default(PENDING)
  sentAt          DateTime?
  error           String?
  createdAt       DateTime                     @default(now())

  subscription    Subscription                 @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Idempotency: one notification per subscription per type per day
  @@unique([subscriptionId, type, daysRemaining])
  @@index([subscriptionId])
  @@index([userId])
  @@index([status])
}
