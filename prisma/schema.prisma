generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum BusinessRole {
  OWNER
  ADMIN
  STAFF
}

enum ResourceType {
  PERSON
  ASSET
}

enum ResourceStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
  DELETED
}

model Business {
  id                            String   @id @default(uuid())
  name                          String
  slug                          String   @unique
  timezone                      String
  resourceLabel                 String   @default("Recurso")
  address                       String?
  area                          String?
  remindersEnabled              Boolean  @default(true)
  reminderOffsetsMinutes        Int[]    @default([1440, 120]) // 24h y 2h antes
  emailNotificationsEnabled     Boolean  @default(true)
  whatsappNotificationsEnabled  Boolean  @default(false)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  members           BusinessMember[]
  resources         Resource[]
  services          Service[]
  serviceResources  ServiceResource[]
  customers         Customer[]
  appointments      Appointment[]
  notifications     Notification[]
}

model BusinessMember {
  id         String       @id @default(uuid())
  businessId String
  userId     String       // Supabase Auth user id (UUID en string)
  role       BusinessRole  @default(OWNER)
  createdAt  DateTime      @default(now())

  business   Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
  @@index([businessId])
}

model Resource {
  id         String         @id @default(uuid())
  businessId String
  name       String
  type       ResourceType?
  status     ResourceStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  availabilityRules AvailabilityRule[]
  blocks            ResourceBlock[]
  serviceResources  ServiceResource[]
  appointments      Appointment[]

  // Note: Partial unique index on (businessId, name) WHERE status != 'DELETED'
  // is defined in migration 20260128000000_soft_delete_partial_unique_index
  // This allows reusing names after soft delete.
  @@index([businessId])
  @@index([status])
}

model AvailabilityRule {
  id           String   @id @default(uuid())
  resourceId   String
  dayOfWeek    Int      // 0=Domingo, 1=Lunes, ..., 6=Sábado
  startMinutes Int      // Minutos desde 00:00 (ej: 540 = 09:00)
  endMinutes   Int      // Minutos desde 00:00 (ej: 1080 = 18:00)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resource     Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
  @@index([resourceId, dayOfWeek])
}

model Service {
  id                      String        @id @default(uuid())
  businessId              String
  name                    String
  description             String?
  durationMinutes         Int
  slotIntervalMinutes     Int           // Periodicidad: cada cuántos minutos se ofrece un nuevo turno
  minBookingNoticeMinutes Int           @default(0) // Anticipación mínima para reservas (minutos)
  priceCents              Int?
  currency                String?       @default("ARS")
  status                  ServiceStatus @default(ACTIVE)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceResources ServiceResource[]
  appointments     Appointment[]

  // Note: Partial unique index on (businessId, name) WHERE status != 'DELETED'
  // is defined in migration 20260128000000_soft_delete_partial_unique_index
  // This allows reusing names after soft delete.
  @@index([businessId])
  @@index([businessId, status])
}

model ResourceBlock {
  id         String   @id @default(uuid())
  resourceId String
  startAt    DateTime // timestamptz - inicio del bloqueo (UTC)
  endAt      DateTime // timestamptz - fin del bloqueo (UTC)
  reason     String?  // motivo opcional
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
  @@index([resourceId, startAt, endAt])
}

model ServiceResource {
  id         String   @id @default(uuid())
  businessId String
  serviceId  String
  resourceId String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, resourceId])
  @@index([businessId, serviceId])
  @@index([businessId, resourceId])
}

// ============================================================================
// US-5.4: Customers & Appointments
// ============================================================================

enum AppointmentStatus {
  SCHEDULED
  CANCELLED
  RESCHEDULED
  COMPLETED
}

model Customer {
  id         String   @id @default(uuid())
  businessId String
  fullName   String
  email      String?
  phone      String?
  phoneE164  String?  // Normalized phone in E.164 format for WhatsApp
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, email])
  @@index([businessId, phone])
  // Note: Unique constraint on (businessId, email) WHERE email IS NOT NULL
  // is defined in migration 20260107100000_customer_unique_email
}

model Appointment {
  id                 String            @id @default(uuid())
  businessId         String
  resourceId         String
  serviceId          String
  customerId         String
  status             AppointmentStatus @default(SCHEDULED)
  startAt            DateTime          // timestamptz - inicio del turno (UTC)
  endAt              DateTime          // timestamptz - fin del turno (UTC) = startAt + duration
  occupiedEndAt      DateTime          // timestamptz - fin ocupación (UTC) = startAt + slotInterval
  notes              String?
  cancellationReason String?
  createdByUserId    String?           // null si fue creado por cliente público
  rescheduledFromId  String?           // referencia a appointment original si fue reprogramado
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  business         Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  resource         Resource     @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  service          Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customer         Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rescheduledFrom  Appointment? @relation("RescheduledAppointments", fields: [rescheduledFromId], references: [id])
  rescheduledTo    Appointment[] @relation("RescheduledAppointments")
  notifications    Notification[]

  @@index([businessId, startAt])
  @@index([resourceId, startAt])
  @@index([customerId])
  @@index([status])
}

// ============================================================================
// US-8.1: Notifications
// ============================================================================

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationType {
  CONFIRMATION
  REMINDER
  CANCELLATION
  RESCHEDULED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id            String             @id @default(uuid())
  businessId    String
  appointmentId String
  channel       NotificationChannel
  type          NotificationType
  to            String             // email address
  status        NotificationStatus @default(PENDING)
  scheduledFor  DateTime           // When the notification should be sent
  sentAt        DateTime?          // When it was actually sent
  error         String?            // Error message if failed
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  // Idempotency: prevent duplicate notifications per channel
  // Allows same appointment to have EMAIL and WHATSAPP notifications independently
  @@unique([appointmentId, channel, type, scheduledFor])
  @@index([businessId])
  @@index([appointmentId])
  @@index([status])
  @@index([channel])
}
