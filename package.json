{
    "name": "turnosapp",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "postinstall": "prisma generate",
        "test:setup": "tsx scripts/setup-test-env.ts",
        "test:reset-db": "dotenv -e .env.test -- tsx scripts/reset-test-db.ts",
        "test": "dotenv -e .env.test -- vitest run",
        "test:watch": "dotenv -e .env.test -- vitest",
        "test:ui": "dotenv -e .env.test -- vitest --ui",
        "test:coverage": "dotenv -e .env.test -- vitest run --coverage",
        "e2e": "dotenv -e .env.test -- playwright test",
        "e2e:ui": "dotenv -e .env.test -- playwright test --ui"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.2.0",
        "@prisma/client": "^7.2.0",
        "@radix-ui/react-accordion": "^1.2.12",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@supabase/ssr": "^0.8.0",
        "@supabase/supabase-js": "^2.89.0",
        "axios": "^1.13.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.562.0",
        "next": "16.1.1",
        "pg": "^8.16.3",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "tailwind-merge": "^3.4.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.4"
    },
    "devDependencies": {
        "@playwright/test": "^1.57.0",
        "@tailwindcss/postcss": "^4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^5.1.2",
        "@vitest/coverage-v8": "^4.0.16",
        "@vitest/ui": "^4.0.16",
        "dotenv": "^17.2.3",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.1.1",
        "jsdom": "^27.4.0",
        "prisma": "^7.2.0",
        "supabase": "^2.70.5",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5",
        "vite-tsconfig-paths": "^6.0.3",
        "vitest": "^4.0.16"
    }
}
